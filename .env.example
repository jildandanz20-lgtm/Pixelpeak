# ============================================
# PIXELPEAK SMP — Environment Variables
# Copy file ini jadi .env untuk local dev
# Di Railway: set via dashboard → Variables
# ============================================

# PostgreSQL (Railway otomatis set ini)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Clerk Auth — ambil dari dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email akun yang jadi admin pertama
ADMIN_EMAIL=emailkamu@gmail.com

# Port (Railway set otomatis, jangan diubah)
PORT=3000
